# Supabase — get these from your Supabase project dashboard (Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For import scripts only (service role bypasses RLS — never put this in the app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stored as a Supabase Edge Function secret, NOT here
# Set via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=
